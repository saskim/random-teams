#!/usr/bin/env bash
# Validates conventional commit format: <type>[optional scope]: <description>
set -euo pipefail

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Skip merge commits
if echo "$commit_msg" | grep -qE '^Merge '; then
  exit 0
fi

pattern='^(feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert)(\([a-z0-9 ,/-]+\))?: .{1,100}$'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  ✗ Commit message does not follow conventional commit format."
  echo ""
  echo "  Expected:  <type>[optional scope]: <description>"
  echo "  Types:     feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert"
  echo ""
  echo "  Examples:"
  echo "    feat: add tournament bracket view"
  echo "    fix(players): prevent duplicate names"
  echo "    chore: upgrade angular to v22"
  echo ""
  echo "  Your message: $commit_msg"
  echo ""
  exit 1
fi
